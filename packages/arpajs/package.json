    "mocha": "^11.7.5",
    "mocha-ctrf-json-reporter": "^0.0.10",
    "nodemon": "^3.1.14",
    "nyc": "^18.0.0",
    "pg": "^8.19.0",
    "pg-query-stream": "^4.13.0",
    "pm2": "^6.0.14",
    "prettier": "^3.8.1",

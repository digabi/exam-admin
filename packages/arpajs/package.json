{
  "name": "arpa-js",
  "version": "1.0.0",
  "description": "Arpa 2",
  "main": "arpa.js",
  "private": true,
  "scripts": {
    "copy-files": "scripts/copy-files.sh",
    "add-ktp-koe-update": "scripts/add-ktp-koe-update.sh",
    "server:compile": "npm run copy-files && npm run add-ktp-koe-update && tsc -p server",
    "server:watch": "npm run copy-files && npm run add-ktp-koe-update && tsc -p server -w --preserveWatchOutput",
    "compile": "npm run server:compile",
    "watch": "npm run server:watch & APP_ENV=development nodemon --config nodemon.json ./bin/arpajs & wait",
    "lint": "eslint bin/arpajs . --ext .js,.ts --quiet",
    "test": "tsc --noEmit && APP_ENV=unit-tests nyc --reporter text mocha",
    "create-migration": "create-migration",
    "db:migrate": "npm run server:compile && APP_ENV=development ./bin/run-migrations.js",
    "db:migrate-unittests": "npm run server:compile && APP_ENV=unit-tests ./bin/run-migrations.js",
    "s3:create-dev-buckets": "npm run server:compile && APP_ENV=development ./bin/create-dev-buckets.js",
    "dev:start": "npm run server:compile && APP_ENV=development ./bin/run-migrations.js && npm run watch",
    "start": "node ./bin/arpajs"
  },
  "author": "",
  "dependencies": {
    "@aws-sdk/client-ecr": "^3.999.0",
    "@aws-sdk/client-s3": "^3.999.0",
    "@aws-sdk/client-secrets-manager": "^3.999.0",
    "@aws-sdk/client-sqs": "^3.999.0",
    "@aws-sdk/client-ssm": "^3.999.0",
    "@aws-sdk/client-sts": "^3.999.0",
    "@aws-sdk/lib-storage": "^3.999.0",
    "@aws-sdk/node-http-handler": "3.374.0",
    "@digabi/answer-utils": "^0.0.2",
    "@digabi/crypto-utils": "^1.0.5",
    "@digabi/database-utils": "^0.0.7",
    "@digabi/exam-engine-exams": "^23.21.0",
    "@digabi/exam-engine-generator": "^23.21.0",
    "@digabi/exam-engine-mastering": "^23.20.6",
    "@digabi/express-utils": "^0.2.0",
    "@digabi/fetch": "^2.1.2",
    "@digabi/json-exam-utils": "^0.1.0",
    "@digabi/logger": "^3.0.0",
    "@digabi/passphrase-generator": "^0.0.2",
    "@digabi/testing": "^0.0.6",
    "@digabi/typescript-config": "^2.0.0",
    "@digabi/validation": "^3.1.0",
    "@digabi/zip-utils": "^1.0.0",
    "@ffprobe-installer/ffprobe": "^2.0.0",
    "@types/ramda": "^0.31.1",
    "@types/sanitize-html": "^2.6.1",
    "bluebird": "^3.4.5",
    "body-parser": "^2.2.2",
    "commander": "^14.0.3",
    "crypto-js": "^4.0.0",
    "date-fns": "^4.1.0",
    "express": "^5.2.1",
    "file-type": "^16.5.3",
    "helmet": "^8.0.0",
    "is-my-json-valid": "^2.10.1",
    "jszip": "^3.5.0",
    "lodash": "^4.17.23",
    "mime": "^3.0.0",
    "moment": "^2.29.4",
    "multer": "^2.1.1",
    "music-metadata": "^7.0.2",
    "nodemailer": "^8.0.1",
    "partial.lenses": "^14.17.0",
    "partial.lenses.validation": "^2.0.0",

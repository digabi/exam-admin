#!/usr/bin/env node
// eslint-disable-next-line no-console
process.on('exit', code => console.info(`Exiting with code ${code}`))
require('source-map-support').install()
const { logger } = require('../dist/logger')
const { loadConfig } = require('../dist/config')
const { promisify } = require('util')

loadConfig()
  .then(config => {
    const pgrm = require('../dist/db/local-pg-resource-management').pgrm
    const http = require('http')
    const https = require('https')

    // Enable Keep-Alive by default for better performance.
    http.globalAgent.keepAlive = true
    https.globalAgent.keepAlive = true

    function startServer() {
      const app = require('../dist/arpa.js').default
      const server = app.listen(config.port, config.interface, () => {
        logger.info(`Express server listening on ${server.address().address}:${server.address().port}`)
      })
      server.keepAliveTimeout = 250000

      function terminateGracefully(signal) {
        process.on(signal, () => {
          logger.info(`Received ${signal} exiting...`)
          const serverCloseAsync = promisify(server.close.bind(server))
          serverCloseAsync()
            .then(() => pgrm.end())
            .catch(err => {
              logger.error('Error terminating gracefully', err)
            })
            .finally(() => {
              logger.info(`Exit at ${new Date().toISOString()}`)
              process.exit()
            })
        })
      }

      terminateGracefully('SIGINT')
      terminateGracefully('SIGTERM')
    }

    startServer()
    return
  })
  .catch(error => {
    logger.error('Error while loading app configuration. Shutting down', { error })
  })

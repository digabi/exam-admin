{
  "name": "sa",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "server:compile": "tsc --project server",
    "server:watch": "tsc --project server -w --preserveWatchOutput",
    "webpack:compile": "webpack --mode production",
    "webpack:compile-dev": "webpack --mode development",
    "compile": "concurrently 'npm run server:compile' 'npm run webpack:compile'",
    "watch": "concurrently 'npm run server:watch' 'APP_ENV=development nodemon --config nodemon.json ./bin/sa'",
    "dev:start": "npm run server:compile && npm run watch",
    "start": "node ./bin/sa",
    "frontend-typecheck": "tsc --noEmit --project public/js",
    "lint": "(rc=0; npm run frontend-typecheck || rc=$?; eslint . --quiet || rc=$?; exit $rc)",
    "test": "APP_ENV=development nyc --reporter text mocha",
    "production": "npm run compile"
  },
